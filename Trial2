ian_val)\n    else:\n        mode_val = train[col].mode()[0]\n        train[col] = train[col].fillna(mode_val)\n        if col in test.columns:\n            test[col] = test[col].fillna(mode_val)\n\ntrain = train.replace([np.inf, -np.inf], np.nan).fillna(train.median())\ntest = test.replace([np.inf, -np.inf], np.nan).fillna(train.median())\n\nconstant_cols = [c for c in train.columns if train[c].nunique() <= 1]\ntrain = train.drop(columns=constant_cols)\ntest = test.drop(columns=constant_cols)\n\nif 'magnitude' in train.columns:\n    target = train['magnitude']\n    features = [c for c in train.columns if c != 'magnitude' and c in test.columns]\n    train = train[features + ['magnitude']]\n    test = test[features]\nelse:\n    raise ValueError(\"Target column 'magnitude' not found in train dataset\")\n\nprint(\"Cleaned train shape:\", train.shape)\nprint(\"Cleaned test shape:\", test.shape)\n\n# ================================\n# 4. Generate sample_submission (baseline)\n# ================================\npossible_ids = [c for c in test.columns if any(x in c.lower() for x in [\"id\",\"record\",\"sample\",\"event\"])]\nif possible_ids:\n    id_col = possible_ids[0]\n    sample_submission = pd.DataFrame({\n        \"ID\": test[id_col],\n        \"Magnitude\": target.mean()\n    })\nelse:\n    test[\"ID\"] = np.arange(1, len(test) + 1)\n    id_col = \"ID\"\n    sample_submission = pd.DataFrame({\n        \"ID\": test[id_col],\n        \"Magnitude\": target.mean()\n    })\n\nsample_submission.to_csv(\"submission.csv\", index=False)\nprint(\"Sample submission created with baseline mean predictions.\")\nprint(sample_submission.head())\n\n# ================================\n# 5. Preprocessing\n# ================================\nX = train.drop(columns=['magnitude'])\ny = target\n\nscaler = StandardScaler()\nX_scaled = scaler.fit_transform(X)\n\n# Drop ID before scaling to avoid mismatch (if any)\ntest_features = test.drop(columns=[\"ID\"], errors=\"ignore\")\ntest_scaled = scaler.transform(test_features)\n\n# keep a simple holdout split for NN models\nX_train, X_val, y_train, y_val = train_test_split(\n    X_scaled, y, test_size=0.2, random_state=50\n)\n\n# ================================\n# 6. Random Forest (baseline tree model)\n# ================================\nrf = RandomForestRegressor(\n    n_estimators=600,\n    max_depth=None,\n    min_samples_leaf=1,\n    random_state=42,\n    n_jobs=-1\n)\nrf.fit(X_train, y_train)\ny_pred_rf_val = rf.predict(X_val)\nprint(\"Random Forest RMSE (holdout):\", np.sqrt(mean_squared_error(y_val, y_pred_rf_val)))\n\n# ================================\n# 7. K-Fold setup for boosting models\n# ================================\nkf = KFold(n_splits=5, shuffle=True, random_state=42)\n\noof_xgb = np.zeros(len(X))\noof_lgb = np.zeros(len(X))\ntest_pred_xgb = np.zeros(len(test_scaled))\ntest_pred_lgb = np.zeros(len(test_scaled))\n\n# ================================\n# 8. XGBoost with 5-fold CV (fixed eval_metric)\n# ================================\nfor fold, (tr_idx, val_idx) in enumerate(kf.split(X_scaled)):\n    print(f\"XGB Fold {fold+1}\")\n    X_tr, X_va = X_scaled[tr_idx], X_scaled[val_idx]\n    y_tr, y_va = y.iloc[tr_idx], y.iloc[val_idx]\n\n    xgb_model = xgb.XGBRegressor(\n        n_estimators=600,\n        learning_rate=0.03,\n        max_depth=5,\n        subsample=0.8,\n        colsample_bytree=0.8,\n        reg_lambda=1.0,\n        random_state=42,\n        tree_method=\"hist\",\n        eval_metric=\"rmse\"\n    )\n\n    xgb_model.fit(\n        X_tr, y_tr,\n        eval_set=[(X_va, y_va)],\n        verbose=False\n    )\n\n    oof_xgb[val_idx] = xgb_model.predict(X_va)\n    test_pred_xgb += xgb_model.predict(test_scaled) / kf.n_splits\n\nprint(\"XGBoost CV RMSE:\", np.sqrt(mean_squared_error(y, oof_xgb)))\n\n# ================================\n# 9. LightGBM with 5-fold CV (callbacks for early stopping)\n# ================================\nfor fold, (tr_idx, val_idx) in enumerate(kf.split(X_scaled)):\n    print(f\"LGB Fold {fold+1}\")\n    X_tr, X_va = X_scaled[tr_idx], X_scaled[val_idx]\n    y_tr, y_va = y.iloc[tr_idx], y.iloc[val_idx]\n\n    lgb_train = lgb.Dataset(X_tr, y_tr)\n    lgb_val = lgb.Dataset(X_va, y_va, reference=lgb_train)\n\n    params = {\n        'objective': 'regression',\n        'metric': 'rmse',\n        'learning_rate': 0.03,\n        'num_leaves': 63,\n        'feature_fraction': 0.9,\n        'bagging_fraction': 0.9,\n        'bagging_freq': 5,\n        'verbose': -1,\n        'seed': 45\n    }\n\n    lgb_model = lgb.train(\n        params,\n        lgb_train,\n        num_boost_round=8000,\n        valid_sets=[lgb_train, lgb_val],\n        callbacks=[\n            early_stopping(stopping_rounds=200),\n            log_evaluation(period=0)\n        ]\n    )\n\n    oof_lgb[val_idx] = lgb_model.predict(\n        X_va,\n        num_iteration=lgb_model.best_iteration\n    )\n    test_pred_lgb += lgb_model.predict(\n        test_scaled,\n        num_iteration=lgb_model.best_iteration\n    ) / kf.n_splits\n\nprint(\"LightGBM CV RMSE:\", np.sqrt(mean_squared_error(y, oof_lgb)))\n\n# ================================\n# 10. MLP (kept for experimentation)\n# ================================\nmlp = keras.Sequential([\n    layers.Input(shape=(X_train.shape[1],)),\n    layers.Dense(128, activation='relu'),\n    layers.Dropout(0.3),\n    layers.Dense(64, activation='relu'),\n    layers.Dense(1)\n])\n\nmlp.compile(optimizer='adam', loss='mse', metrics=['mae'])\nmlp.fit(\n    X_train, y_train,\n    validation_data=(X_val, y_val),\n    epochs=20,\n    batch_size=32,\n    verbose=1\n)\n\nval_loss_mlp, val_mae_mlp = mlp.evaluate(X_val, y_val, verbose=0)\nprint(\"MLP MAE (holdout):\", val_mae_mlp)\n\n# ================================\n# 11. CNN (kept for experimentation)\n# ================================\nX_train_cnn = X_train.reshape(-1, X_train.shape[1], 1)\nX_val_cnn   = X_val.reshape(-1, X_val.shape[1], 1)\ntest_cnn    = test_scaled.reshape(-1, test_scaled.shape[1], 1)\n\ncnn = keras.Sequential([\n    layers.Conv1D(64, kernel_size=3, activation='relu', input_shape=(X_train.shape[1],1)),\n    layers.MaxPooling1D(pool_size=2),\n    layers.Conv1D(128, kernel_size=3, activation='relu'),\n    layers.GlobalAveragePooling1D(),\n    layers.Dense(64, activation='relu'),\n    layers.Dense(1)\n])\n\ncnn.compile(optimizer='adam', loss='mse', metrics=['mae'])\ncnn.fit(\n    X_train_cnn, y_train,\n    validation_data=(X_val_cnn, y_val),\n    epochs=20,\n    batch_size=32,\n    verbose=1\n)\n\nval_loss_cnn, val_mae_cnn = cnn.evaluate(X_val_cnn, y_val, verbose=0)\nprint(\"CNN MAE (holdout):\", val_mae_cnn)\n\ntest_preds_cnn = cnn.predict(test_cnn).flatten()\n\n# ================================\n# 12. Safe ID handling\n# ================================\npossible_ids = [c for c in test.columns if any(x in c.lower() for x in [\"id\",\"record\",\"sample\",\"event\"])]\nif possible_ids:\n    id_col = possible_ids[0]\n    test = test.rename(columns={id_col: \"ID\"})\n    id_col = \"ID\"\n    print(f\"Detected and renamed ID column: {id_col}\")\nelse:\n    test[\"ID\"] = np.arange(1, len(test) + 1)\n    id_col = \"ID\"\n    print(\"No ID column found вЂ” created sequential IDs.\")\n\ntest = test.reset_index(drop=True)\n\nprint(\"Test rows:\", len(test))\nprint(\"Prediction arrays:\",\n      len(test_pred_xgb),\n      len(test_pred_lgb))\n\n# ================================\n# 13. Final Blended Prediction & Submission\n# ================================\nw_xgb = 0.4\nw_lgb = 0.4\nw_rf  = 0.2\nw_cnn = 0.0  # you can try 0.1 later\n\ntest_pred_rf_full = rf.predict(test_scaled)\n\ntest_blend = (\n    w_xgb * test_pred_xgb +\n    w_lgb * test_pred_lgb +\n    w_rf  * test_pred_rf_full +\n    w_cnn * test_preds_cnn\n)\n\nif len(test_blend) != len(test):\n    raise ValueError(f\"Mismatch: {len(test_blend)} predictions vs {len(test)} test rows\")\n\nsubmission = pd.DataFrame({\n    \"ID\": test[\"ID\"],\n    \"Magnitude\": t