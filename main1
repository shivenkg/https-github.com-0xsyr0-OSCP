leted"},"tags":[]}},{"id":"c1f7f4d1","cell_type":"code","source":"def add_features(df, feat_cols, ref_df):\n    \"\"\"ref_df = train, used to fit quantile bins.\"\"\"\n    d = df.copy()\n    num = feat_cols  # all 20 are numeric\n\n    # ── Per-feature transforms ──────────────────────────────────────────\n    for c in num:\n        d[f'{c}_sq']    = d[c] ** 2\n        d[f'{c}_cu']    = d[c] ** 3\n        d[f'{c}_sqrt']  = np.sqrt(d[c].abs())\n        d[f'{c}_log']   = np.log1p(d[c].abs())\n        d[f'{c}_recip'] = 1.0 / (d[c].abs() + 1e-6)\n        d[f'{c}_abs']   = d[c].abs()\n        d[f'{c}_sign']  = np.sign(d[c])\n        # quantile bin (fitted on train)\n        try:\n            _, bins = pd.qcut(ref_df[c], q=4, duplicates='drop', retbins=True)\n            d[f'{c}_qbin'] = pd.cut(d[c], bins=bins, labels=False,\n                                    include_lowest=True).fillna(-1).astype(int)\n        except Exception:\n            pass\n\n    # ── Pairwise interactions ────────────────────────────────────────────\n    for i in range(len(num)):\n        for j in range(i + 1, len(num)):\n            a, b = num[i], num[j]\n            d[f'{a}*{b}']   = d[a] * d[b]\n            d[f'{a}/{b}']   = d[a] / (d[b].abs() + 1e-9)\n            d[f'{a}-{b}']   = d[a] - d[b]\n            d[f'{a}+{b}']   = d[a] + d[b]\n            d[f'h_{a}_{b}'] = np.sqrt(d[a]**2 + d[b]**2)   # L2 norm\n\n    # ── Row-level aggregates ─────────────────────────────────────────────\n    base = d[num]\n    d['r_mean']   = base.mean(axis=1)\n    d['r_std']    = base.std(axis=1)\n    d['r_min']    = base.min(axis=1)\n    d['r_max']    = base.max(axis=1)\n    d['r_range']  = d['r_max'] - d['r_min']\n    d['r_sum']    = base.sum(axis=1)\n    d['r_median'] = base.median(axis=1)\n    d['r_skew']   = base.skew(axis=1)\n    d['r_kurt']   = base.kurt(axis=1)\n    d['r_q25']    = base.quantile(0.25, axis=1)\n    d['r_q75']    = base.quantile(0.75, axis=1)\n    d['r_iqr']    = d['r_q75'] - d['r_q25']\n    d['r_cv']     = d['r_std'] / (d['r_mean'].abs() + 1e-6)\n    d['r_n_pos']  = (base > 0).sum(axis=1)\n    d['r_n_neg']  = (base < 0).sum(axis=1)\n    d['r_l1norm'] = base.abs().sum(axis=1)\n    d['r_l2norm'] = np.sqrt((base**2).sum(axis=1))\n\n    return d\n\nprint('Engineering features...')\ntr_eng = add_features(train, feat_cols, ref_df=train)\nte_eng = add_features(test,  feat_cols, ref_df=train)\n\ndrop = [TARGET] + ([id_col] if id_col else [])\nall_feats = [c for c in tr_eng.columns if c not in drop]\nprint(f'Total features: {len(all_feats)}')","metadata":{"execution":{"iopub.status.busy":"2026-05-08T10:11:26.387827Z","iopub.execute_input":"2026-05-08T10:11:26.388181Z","iopub.status.idle":"2026-05-08T10:11:28.242773Z","shell.execute_reply.started":"2026-05-08T10:11:26.388151Z","shell.execute_reply":"2026-05-08T10:11:28.241979Z"},"papermill":{"duration":1.912871,"end_time":"2026-05-05T20:52:19.065957+00:00","exception":false,"start_time":"2026-05-05T20:52:17.153086+00:00","status":"completed"},"tags":[],"trusted":true},"outputs":[{"name":"stdout","text":"Engineering features...\nTotal features: 1147\n","output_type":"stream"}],"execution_count":6},{"id":"003023be","cell_type":"markdown","source":"## 5 · Impute → Select → Sclale ","metadata":{"papermill":{"duration":0.003879,"end_time":"2026-05-05T20:52:19.073725+00:00","exception":false,"start_time":"2026-05-05T20:52:19.069846+00:00","status":"completed"},"tags":[]}},{"id":"6a3ec06b","cell_type":"code","source":"X      = tr_eng[all_feats].replace([np.inf, -np.inf], np.nan)\nX_test = te_eng[all_feats].replace([np.inf, -np.inf], np.nan)\n\n# ── KNN Imputation ───────────────────────────────────────────────────────\nprint('KNN imputing...')\nimp = KNNImputer(n_neighbors=7)\nX      = pd.DataFrame(imp.fit_transform(X),      columns=all_feats)\nX_test = pd.DataFrame(imp.transform(X_test),     columns=all_feats)\nprint(f'  NaN remaining — train:{X.isnull().sum().sum()}  test:{X_test.isnull().sum().sum()}')\n\n# ── Var